<div class="gallery">
    @foreach (var item in Model)
    {
   

        <div class="gallery-item">
            <a data-toggle="modal" data-target="#@item.Id.ToString()"><div class="cropthumb"><img src="@Url.Content(item.ImageUrl)"></div></a>
            <div id="@item.Id.ToString()" class="modal fade" role="dialog">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">×</span><span class="sr-only">Close</span></button>
                            <div class="img-caption">
                                <h4 class="img-title">@item.Title</h4>
                                <p class="img-subtitle">@item.Description</p>
                            </div>

                        </div>
                        <div class="modal-body">
                            <img src="@Url.Content(item.ImageUrl)" class="img-responsive">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
